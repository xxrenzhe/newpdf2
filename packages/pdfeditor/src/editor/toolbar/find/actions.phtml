<div class="__act_item __act_item_find">
    <div class="child-item child-item-title">
        <input type="text" class="__find_input" data-locale="find" data-locale-attrs="placeholder" />
    </div>
    <button type="button" class="__find_prev">Prev</button>
    <button type="button" class="__find_next">Next</button>
    <label class="__find_case_label" title="Match case">
        <input type="checkbox" class="__find_case" />
        <span>Aa</span>
    </label>
    <span class="__find_status" aria-live="polite"></span>
</div>
<div class="__act_item __act_item_find_replace">
    <div class="child-item child-item-title">
        <input type="text" class="__replace_input" data-locale="replace" data-locale-attrs="placeholder" />
    </div>
    <button type="button" class="__find_replace_current" data-locale="replace">${LANG_MESSAGES.replace}</button>
    <button type="button" class="__find_replace_all" data-locale="replace_all">${LANG_MESSAGES.replace_all}</button>
</div>
